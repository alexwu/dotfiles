{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/prefer-rg.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/validate-git-add.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/notify.py PreToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/notify.py Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf \"\\e]777;notify;%s;%s\\e\\\\\" \"Claude Code\" \"Awaiting your input\""
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/notify.py Notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "ast-grep@ast-grep-marketplace": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "obsidian@obsidian-skills": false,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "xcsift@xcsift": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "mind@memvid": true,
    "swift-lsp@claude-plugins-official": true,
    "skill-codex@skill-codex": true,
    "basedpyright@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "rust-analyzer@claude-code-lsps": true,
    "ruby-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {
    "skill-codex": {
      "source": {
        "source": "github",
        "repo": "skills-directory/skill-codex"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "git",
        "url": "https://github.com/Piebald-AI/claude-code-lsps.git"
      }
    }
  },
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754024913722
  }
}
