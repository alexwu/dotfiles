{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "0"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(/tmp/**)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "mcp__plugin_github_github__issue_read",
      "mcp__plugin_github_github__pull_request_read",
      "Bash(ls *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(command -v *)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(uname *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)"
    ],
    "deny": [
      "Agent(Explore)"
    ],
    "ask": [
      "Bash(heroku run:*)",
      "Bash(heroku ps:*)",
      "Bash(heroku config:set*)",
      "Bash(heroku pg:*)",
      "Bash(heroku restart*)",
      "Bash(heroku scale*)",
      "Bash(railway run:*)",
      "Bash(railway up*)",
      "Bash(railway redeploy*)",
      "Bash(railway down*)",
      "Bash(railway service*)",
      "Bash(railway variables*)",
      "Bash(railway volume*)",
      "Bash(gh release create*)",
      "Bash(npm publish*)",
      "Bash(cargo publish*)",
      "Bash(chezmoi apply*)",
      "Bash(chezmoi destroy*)",
      "Bash(chezmoi purge*)",
      "Bash(chezmoi forget*)",
      "Bash(chezmoi init*)",
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(brew bundle*)",
      "Bash(brew tap*)",
      "Bash(brew untap*)",
      "Bash(mise install*)",
      "Bash(mise use*)",
      "Bash(mise uninstall*)",
      "Bash(mise plugin*)",
      "Bash(cargo install*)",
      "Bash(cargo binstall*)",
      "Bash(cargo uninstall*)",
      "Bash(npm install -g*)",
      "Bash(npm i -g*)",
      "Bash(bun install -g*)",
      "Bash(bun add -g*)",
      "Bash(bun i -g*)",
      "Bash(pnpm add -g*)",
      "Bash(yarn global add*)",
      "Bash(gem install*)",
      "Bash(pipx install*)",
      "Bash(pipx uninstall*)",
      "Bash(uv tool install*)",
      "Bash(uv tool uninstall*)",
      "Bash(uv pip install*)",
      "Bash(pip install*)",
      "Bash(nimble install*)",
      "Bash(go install*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/secret-guard",
            "statusMessage": "Checking for sensitive paths..."
          },
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/git-add-guard",
            "statusMessage": "Checking git add pattern..."
          },
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/truncation-guard",
            "statusMessage": "Checking for output truncation..."
          },
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/wezterm-guard",
            "statusMessage": "Checking for destructive wezterm cli..."
          },
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/git-confirm-guard",
            "statusMessage": "Confirming git commit/push..."
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/notify PreToolUse"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/sec-guard check",
            "timeout": 5,
            "statusMessage": "Security check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/reward-anchor pretooluse",
            "timeout": 5,
            "statusMessage": "Scope check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/notify Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/notify Notification"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/sec-guard cleanup",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/persona-anchor session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/persona-anchor prompt-submit",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/jamesbombeelu/.local/bin/reward-anchor reset",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "basedpyright@claude-code-lsps": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-code-plugins": true,
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "railway@claude-plugins-official": true,
    "ruby-lsp@claude-code-lsps": true,
    "ruby-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "rust-analyzer@claude-code-lsps": true,
    "security-guidance@claude-plugins-official": false,
    "skill-codex@skill-codex": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "vtsls@claude-code-lsps": true,
    "xcsift@xcsift": true,
    "clangd-lsp@claude-plugins-official": true,
    "remember@claude-plugins-official": false,
    "coderabbit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "nono@always-further": true,
    "figma@claude-plugins-official": true,
    "clangd@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {
    "claude-code-lsps": {
      "source": {
        "source": "git",
        "url": "https://github.com/Piebald-AI/claude-code-lsps.git"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "skill-codex": {
      "source": {
        "source": "github",
        "repo": "skills-directory/skill-codex"
      }
    },
    "xcsift": {
      "source": {
        "source": "github",
        "repo": "ldomaradzki/xcsift"
      }
    },
    "axiom-marketplace": {
      "source": {
        "source": "github",
        "repo": "CharlesWiltgen/Axiom"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "editorMode": "vim",
  "verbose": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754024913722
  }
}
