[group("llm")]
[doc("Conventional Commit message for staged diff via `llm`: J llm-commit-message [-p PROVIDER] [-m MODEL]")]
[arg("model", long, short="m")]
[arg("provider", long, short="p")]
[no-cd]
llm-commit-message provider="codex" model="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -z $(git diff --cached --stat 2>/dev/null) ]]; then
        echo "llm-commit-message: nothing staged. Run 'git add <files>' first." >&2
        exit 1
    fi
    args=(--provider {{ quote(provider) }})
    if [[ -n {{ quote(model) }} ]]; then
        args+=(--model {{ quote(model) }})
    fi
    git diff --cached | llm "${args[@]}" 'Write a single git commit message for this staged diff.

    Format (Conventional Commits):
    - Subject: `type(scope): Description`
    - Type is one of: feat, fix, chore, docs, style, refactor, perf, test
    - THIRD-PERSON SINGULAR PRESENT TENSE — `Adds`, `Fixes`, `Bumps`, `Reworks`, `Removes`.
      NOT imperative — never `Add`, `Fix`, `Bump`, `Rework`, `Remove`.
    - First letter of the Description capitalized
    - No trailing period on the subject
    - Subject under 72 chars
    - Scope: short slug derived from the file paths / feature area in the diff
    - Example: `feat(auth): Adds password reset functionality`

    Body (optional, only when worth saying):
    - Dry. List detailed changes factually.
    - Do NOT "sell" the changes — no marketing language, no superlatives.
    - Wrap at ~72 chars.
    - Blank line between subject and body.

    Output ONLY the commit message. No preamble, no code fences, no explanation.'

[group("tree-sitter")]
[doc("Refresh tree-sitter grammars: hx fetch + build, then rebuild tree-sitter-<lang> symlinks")]
ts-grammars-update:
    #!/usr/bin/env bash
    set -euo pipefail
    hx --grammar fetch
    hx --grammar build
    SOURCES_DIR="$HOME/.config/helix/runtime/grammars/sources"
    PARSERS_DIR="$HOME/.local/share/tree-sitter/parsers"
    mkdir -p "$PARSERS_DIR"
    find "$PARSERS_DIR" -maxdepth 1 -type l -name 'tree-sitter-*' -delete
    count=0
    for src in "$SOURCES_DIR"/*/; do
        [[ -d "$src" ]] || continue
        src="${src%/}"
        ln -sf "$src" "$PARSERS_DIR/tree-sitter-$(basename "$src")"
        count=$((count + 1))
    done
    echo "linked $count grammars into $PARSERS_DIR"

[group("tree-sitter")]
[doc("List tree-sitter grammars currently linked for the CLI")]
ts-grammars-list:
    tree-sitter dump-languages | rg '^scope:'

[group("lumis")]
[doc("Highlight FILE via lumis (snazzy theme); falls back to bat for filetypes lumis doesn't recognize.")]
[no-cd]
hl FILE:
    #!/usr/bin/env bash
    set -euo pipefail
    file="{{ FILE }}"
    # lumis emits ANSI when it has a grammar; otherwise prints plaintext.
    # Detect that and fall back to bat for richer language coverage.
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    lumis highlight -t snazzy "$file" 2>/dev/null > "$tmp" || true
    if rg -q --max-count=1 $'\x1b\\[' "$tmp"; then
        cat "$tmp"
    else
        exec bat --color=always --paging=never --style=plain "$file"
    fi

[group("lumis")]
[doc("Regenerate snazzy theme JSON for lumis. Re-adds to chezmoi source on success.")]
lumis-regen-snazzy:
    #!/usr/bin/env bash
    set -euo pipefail
    out="$HOME/.local/share/lumis/themes/snazzy.json"
    lumis themes generate \
        -u https://github.com/alexwu/nvim-snazzy \
        -c snazzy \
        -s 'vim.pack.add({{{{ src = "https://github.com/rktjmp/lush.nvim" }}}}, { load = true, confirm = false }); vim.opt.runtimepath:prepend(vim.fn.stdpath("data") .. "/site/pack/core/opt/lush.nvim")' \
        -o "$out"
    chezmoi re-add "$out"
