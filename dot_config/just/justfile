        echo "$body" | xh --stream POST {{ LLAMA_SWAP }}/v1/responses
    else
        echo "$body" | xh -b POST {{ LLAMA_SWAP }}/v1/responses
    fi

[group("llama-swap")]
[doc("Responses API with prompt from stdin: cat file.txt | just llm-respond-pipe [-m MODEL] [--stream]")]
[arg("model", long, short="m")]
[arg("stream", long, value="true")]
llm-respond-pipe model=LLM_DEFAULT_MODEL stream="false":
    #!/usr/bin/env bash
    set -euo pipefail
    prompt=$(cat)
    body=$(jaq -n --arg m {{ quote(model) }} --arg p "$prompt" --argjson s {{ stream }} \
