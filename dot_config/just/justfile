[group("llama-swap")]
[doc("Pick a model interactively and print the chosen id: just llm-pick [-p PICKER]")]
[arg("picker", long, short="p")]
llm-pick picker="choose":
    xh -b GET {{ LLAMA_SWAP }}/v1/models | jaq -r '.data[].id' | {{ picker }}

[group("llama-swap")]
[doc("Pick a model interactively, then chat: just llm-chat-pick [--stream] [-p PICKER] PROMPT...")]
[arg("stream", long, value="true")]
[arg("picker", long, short="p")]
llm-chat-pick stream="false" picker="choose" +prompt="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ -z {{ quote(prompt) }} ]]; then
        echo "error: prompt required" >&2
        exit 1
    fi
    model=$(xh -b GET {{ LLAMA_SWAP }}/v1/models | jaq -r '.data[].id' | {{ picker }})
    if [[ -z "$model" ]]; then
        echo "cancelled" >&2
        exit 1
    fi
    body=$(jaq -n --arg m "$model" --arg p {{ quote(prompt) }} --argjson s {{ stream }} \
        '{model: $m, messages: [{role: "user", content: $p}], stream: $s}')
    if [[ "{{ stream }}" == "true" ]]; then
        echo "$body" | xh --stream POST {{ LLAMA_SWAP }}/v1/chat/completions
    else
        echo "$body" | xh -b POST {{ LLAMA_SWAP }}/v1/chat/completions
    fi

