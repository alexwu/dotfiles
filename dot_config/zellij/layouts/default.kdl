layout {
    default_tab_template {
        // ── Top Bar: Tabs ──
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
                // ── Snazzy Color Palette ──
                color_bg      "#282a36"
                color_fg      "#eff0eb"
                color_dark    "#3a3d4d"
                color_subtle  "#606580"
                color_red     "#ff5c57"
                color_green   "#5af78e"
                color_yellow  "#f3f99d"
                color_blue    "#57c7ff"
                color_magenta "#ff6ac1"
                color_cyan    "#9aedfe"
                color_orange  "#FF8227"
                color_purple  "#A39DF9"

                format_left   "#[fg=$purple,bold] {session}"
                format_center "{tabs}"
                format_right  ""
                format_space  ""

                border_enabled  "false"

                hide_frame_for_single_pane       "true"
                hide_frame_except_for_search     "true"
                hide_frame_except_for_scroll     "true"
                hide_frame_except_for_fullscreen "true"

                // ── Tabs ──
                tab_normal              "#[bg=$bg,fg=$subtle]#[bg=$subtle,fg=$bg,bold]{index} #[bg=$bg,fg=$subtle,bold] {name}{floating_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_normal_fullscreen   "#[bg=$bg,fg=$subtle]#[bg=$subtle,fg=$bg,bold]{index} #[bg=$bg,fg=$subtle,bold] {name}{fullscreen_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_normal_sync         "#[bg=$bg,fg=$subtle]#[bg=$subtle,fg=$bg,bold]{index} #[bg=$bg,fg=$subtle,bold] {name}{sync_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_active              "#[bg=$bg,fg=$magenta]#[bg=$magenta,fg=$bg,bold]{index} #[bg=$bg,fg=$magenta,bold] {name}{floating_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_active_fullscreen   "#[bg=$bg,fg=$magenta]#[bg=$magenta,fg=$bg,bold]{index} #[bg=$bg,fg=$magenta,bold] {name}{fullscreen_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_active_sync         "#[bg=$bg,fg=$magenta]#[bg=$magenta,fg=$bg,bold]{index} #[bg=$bg,fg=$magenta,bold] {name}{sync_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_separator           "#[bg=$bg] "
                tab_sync_indicator       " "
                tab_fullscreen_indicator " 󰊓"
                tab_floating_indicator   " 󰹙"
                tab_rename              "#[bg=$bg,fg=$blue]#[bg=$blue,fg=$bg,bold]{index} #[bg=$bg,fg=$blue,bold] {name}{floating_indicator}#[bg=$bg,fg=$bg,bold]"
                tab_display_count         "9"
                tab_truncate_start_format "#[fg=$orange]  +{count}  "
                tab_truncate_end_format   "#[fg=$orange]   +{count} "
            }
        }

        children

        // ── Bottom Bar: Mode + Hints + Status ──
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
                // ── Snazzy Color Palette ──
                color_bg      "#282a36"
                color_fg      "#eff0eb"
                color_dark    "#3a3d4d"
                color_subtle  "#606580"
                color_red     "#ff5c57"
                color_green   "#5af78e"
                color_yellow  "#f3f99d"
                color_blue    "#57c7ff"
                color_magenta "#ff6ac1"
                color_cyan    "#9aedfe"
                color_orange  "#FF8227"
                color_purple  "#A39DF9"

                format_left   "{mode}"
                format_center "{pipe_zjstatus_hints}"
                format_right  "{command_git_branch} {datetime}"
                format_space  ""
                format_hide_on_overlength "true"
                format_precedence         "lcr"

                border_enabled  "false"

                // ── Mode Indicators (pill with right-cap) ──
                mode_normal        "#[bg=$purple,fg=$bg,bold]  NORMAL #[bg=$bg,fg=$purple]"
                mode_locked        "#[bg=$subtle,fg=$fg,bold]  LOCKED #[bg=$bg,fg=$subtle]"
                mode_resize        "#[bg=$orange,fg=$bg,bold] 󰩨 RESIZE #[bg=$bg,fg=$orange]"
                mode_pane          "#[bg=$green,fg=$bg,bold]  PANE #[bg=$bg,fg=$green]"
                mode_move          "#[bg=$yellow,fg=$bg,bold]  MOVE #[bg=$bg,fg=$yellow]"
                mode_tab           "#[bg=$blue,fg=$bg,bold]  TAB #[bg=$bg,fg=$blue]"
                mode_scroll        "#[bg=$cyan,fg=$bg,bold]  SCROLL #[bg=$bg,fg=$cyan]"
                mode_search        "#[bg=$yellow,fg=$bg,bold]  SEARCH #[bg=$bg,fg=$yellow]"
                mode_enter_search  "#[bg=$orange,fg=$bg,bold]  SEARCH #[bg=$bg,fg=$orange]"
                mode_rename_tab    "#[bg=$blue,fg=$bg,bold] 󰏫 RENAME #[bg=$bg,fg=$blue]"
                mode_rename_pane   "#[bg=$green,fg=$bg,bold] 󰏫 RENAME #[bg=$bg,fg=$green]"
                mode_session       "#[bg=$magenta,fg=$bg,bold]  SESSION #[bg=$bg,fg=$magenta]"
                mode_tmux          "#[bg=$red,fg=$bg,bold]  TMUX #[bg=$bg,fg=$red]"
                mode_prompt        "#[bg=$cyan,fg=$bg,bold]  PROMPT #[bg=$bg,fg=$cyan]"

                // ── Git Branch ──
                command_git_branch_command     "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format      "#[fg=$blue]  {stdout} "
                command_git_branch_interval    "10"
                command_git_branch_rendermode  "static"

                // ── Date/Time ──
                datetime          "#[fg=$subtle]  {format} "
                datetime_format   "%a %b %d  %H:%M"
                datetime_timezone "America/Los_Angeles"

                // ── zjstatus-hints (raw ANSI passthrough) ──
                pipe_zjstatus_hints_format     "{output}"
                pipe_zjstatus_hints_rendermode "raw"
            }
        }
    }
}
