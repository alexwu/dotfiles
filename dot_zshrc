# Override zoxide: always show frecency-ranked results on tab
if (( $+commands[zoxide] ))
then
  function __zoxide_z_complete() {
    [[ "${#words[@]}" -eq "${CURRENT}" ]] || return 0
    local -a paths entries local_dirs
    paths=("${(@f)$(zoxide query -l -- ${words[2,-1]} 2>/dev/null)}")
    local p short
    for p in "${paths[@]}"; do
      [[ -z "$p" ]] && continue
      short="${p/#$HOME/~}"
      entries+=("${p:t}:${short}")
    done
    local_dirs=( *(N/) )
    for p in "${local_dirs[@]}"; do
      entries+=("${p}:./${p}")
    done
    _describe 'zoxide directory' entries -U
    return 0
  }
  compdef __zoxide_z_complete z
  zstyle ':completion:*:zoxide-directory:*' sort false
  zstyle ':fzf-tab:complete:z:*' fzf-preview 'eza -1 --color=always $(zoxide query -- $word 2>/dev/null)'
fi

